import os
import sys
import time
from pathlib import Path

import cv2
import gymnasium as gym
import numpy as np
import pygame
import ale_py  # noqa: F401, required for ALE environments to work with Gymnasium

# Requires:
#   pip install gymnasium[atari,accept-rom-license] ale-py pygame opencv-python
#
# This script does NOT include the Montezuma's Revenge ROM.
# You must have a legal Atari ROM installation available to ALE/Gymnasium.
#
# It opens the real Montezuma's Revenge environment, lets you control it with
# the keyboard, and writes an MP4 video when you quit.

ENV_ID = "ALE/MontezumaRevenge-v5"
OUT_DIR = Path("play_recordings")
FPS = 30
SCALE = 4
WINDOW_TITLE = "Montezuma's Revenge - manual play"


# Atari action meanings from ALE docs:
# 0 NOOP, 1 FIRE, 2 UP, 3 RIGHT, 4 LEFT, 5 DOWN,
# 6 UPRIGHT, 7 UPLEFT, 8 DOWNRIGHT, 9 DOWNLEFT,
# 10 UPFIRE, 11 RIGHTFIRE, 12 LEFTFIRE, 13 DOWNFIRE,
# 14 UPRIGHTFIRE, 15 UPLEFTFIRE, 16 DOWNRIGHTFIRE, 17 DOWNLEFTFIRE

def build_action_from_keys(keys: set[int]) -> int:
    up = pygame.K_UP in keys or pygame.K_w in keys
    down = pygame.K_DOWN in keys or pygame.K_s in keys
    left = pygame.K_LEFT in keys or pygame.K_a in keys
    right = pygame.K_RIGHT in keys or pygame.K_d in keys
    fire = pygame.K_SPACE in keys or pygame.K_f in keys

    if up and right and fire:
        return 14
    if up and left and fire:
        return 15
    if down and right and fire:
        return 16
    if down and left and fire:
        return 17
    if up and right:
        return 6
    if up and left:
        return 7
    if down and right:
        return 8
    if down and left:
        return 9
    if up and fire:
        return 10
    if right and fire:
        return 11
    if left and fire:
        return 12
    if down and fire:
        return 13
    if fire:
        return 1
    if up:
        return 2
    if right:
        return 3
    if left:
        return 4
    if down:
        return 5
    return 0


def ensure_dir(path: Path) -> None:
    path.mkdir(parents=True, exist_ok=True)


def create_writer(path: Path, frame_shape: tuple[int, int, int], fps: int) -> cv2.VideoWriter:
    height, width, _ = frame_shape
    fourcc = cv2.VideoWriter_fourcc(*"mp4v")
    writer = cv2.VideoWriter(str(path), fourcc, fps, (width, height))
    if not writer.isOpened():
        raise RuntimeError("Could not open VideoWriter. Try installing ffmpeg/system codecs.")
    return writer


def draw_text(surface: pygame.Surface, font: pygame.font.Font, lines: list[str]) -> None:
    y = 8
    for line in lines:
        text_surface = font.render(line, True, (255, 255, 255))
        shadow_surface = font.render(line, True, (0, 0, 0))
        surface.blit(shadow_surface, (9, y + 1))
        surface.blit(text_surface, (8, y))
        y += 20


def main() -> None:
    ensure_dir(OUT_DIR)
    video_path = OUT_DIR / f"montezuma_play_asd{time.strftime('%Y%m%d_%H%M%S')}.mp4"

    try:
        env = gym.make(ENV_ID, render_mode="rgb_array", full_action_space=True)
    except Exception as exc:
        print("Failed to create the environment.")
        print("Common reason: Montezuma ROM is not installed for ALE/Gymnasium.")
        print(f"Original error: {exc}")
        sys.exit(1)

    pygame.init()
    pygame.display.set_caption(WINDOW_TITLE)
    font = pygame.font.SysFont("consolas", 18)

    obs, info = env.reset()
    frame = env.render()
    if frame is None:
        raise RuntimeError("Environment did not return a frame. Check render_mode='rgb_array'.")

    height, width, _ = frame.shape
    window = pygame.display.set_mode((width * SCALE, height * SCALE))
    clock = pygame.time.Clock()
    writer = create_writer(video_path, frame.shape, FPS)

    pressed_keys: set[int] = set()
    total_reward = 0.0
    episode_reward = 0.0
    episode_idx = 1
    frame_count = 0
    running = True
    paused = False

    print("Controls:")
    print("  Arrows / WASD: move")
    print("  Space or F: fire / jump")
    print("  R: reset episode")
    print("  P: pause")
    print("  ESC or window close: quit and save video")
    print(f"Recording to: {video_path}")

    while running:
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                running = False
            elif event.type == pygame.KEYDOWN:
                pressed_keys.add(event.key)
                if event.key == pygame.K_ESCAPE:
                    running = False
                elif event.key == pygame.K_p:
                    paused = not paused
                elif event.key == pygame.K_r:
                    obs, info = env.reset()
                    episode_reward = 0.0
                    episode_idx += 1
            elif event.type == pygame.KEYUP:
                pressed_keys.discard(event.key)

        if not paused and running:
            action = build_action_from_keys(pressed_keys)
            obs, reward, terminated, truncated, info = env.step(action)
            episode_reward += float(reward)
            total_reward += float(reward)

            if terminated or truncated:
                print(f"Episode {episode_idx} finished with reward {episode_reward:.1f}")
                obs, info = env.reset()
                episode_reward = 0.0
                episode_idx += 1

        frame = env.render()
        if frame is None:
            continue

        writer.write(cv2.cvtColor(frame, cv2.COLOR_RGB2BGR))
        frame_count += 1

        frame_surface = pygame.surfarray.make_surface(np.transpose(frame, (1, 0, 2)))
        frame_surface = pygame.transform.scale(frame_surface, (width * SCALE, height * SCALE))
        window.blit(frame_surface, (0, 0))

        draw_text(
            window,
            font,
            [
                f"Episode: {episode_idx}",
                f"Episode reward: {episode_reward:.1f}",
                f"Total reward: {total_reward:.1f}",
                f"Frames recorded: {frame_count}",
                "P pause | R reset | ESC quit",
            ],
        )

        if paused:
            draw_text(window, font, ["PAUSED"])

        pygame.display.flip()
        clock.tick(FPS)

    writer.release()
    env.close()
    pygame.quit()

    print(f"\nSaved gameplay video to: {video_path.resolve()}")


if __name__ == "__main__":
    main()
